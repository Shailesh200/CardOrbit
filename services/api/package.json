{
  "name": "@cardwise/api",
  "version": "0.0.0",
  "private": true,
  "description": "CardWise NestJS API (Fastify adapter)",
  "scripts": {
    "build": "nest build",
    "dev": "bun --env-file=../../.env.example --env-file=../../.env.local nest start --watch",
    "start": "bun --env-file=../../.env.example --env-file=../../.env.local dist/main.js",
    "lint": "echo '@cardwise/api: lint via root oxlint'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun --env-file=../../.env.example --env-file=../../.env.local vitest run",
    "test:coverage:ai": "vitest run --coverage src/modules/assistant src/modules/rag src/modules/search src/modules/knowledge-graph",
    "db:generate": "bun --env-file=../../.env.example --env-file=../../.env.local prisma generate",
    "db:migrate": "bun --env-file=../../.env.example --env-file=../../.env.local prisma migrate deploy",
    "db:migrate:dev": "bun --env-file=../../.env.example --env-file=../../.env.local prisma migrate dev",
    "db:seed": "bun --env-file=../../.env.example --env-file=../../.env.local src/seed/cli.ts",
    "db:purge": "bun --env-file=../../.env.example --env-file=../../.env.local src/seed/purge-cli.ts",
    "catalog:ingest": "bun --env-file=../../.env.example --env-file=../../.env.local src/scripts/catalog-ingest-cli.ts",
    "reward-expiry:scan": "bun --env-file=../../.env.example --env-file=../../.env.local src/scripts/reward-expiry-scan-cli.ts",
    "notifications:sync": "bun --env-file=../../.env.example --env-file=../../.env.local src/scripts/contextual-notifications-scan-cli.ts",
    "ai:poc": "bun --env-file=../../.env.example --env-file=../../.env.local src/scripts/ai-poc-cli.ts",
    "db:studio": "bun --env-file=../../.env.example --env-file=../../.env.local prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@cardwise/admin-config": "workspace:*",
    "@cardwise/ai": "workspace:*",
    "@cardwise/analytics": "workspace:*",
    "@cardwise/catalog-ingest": "workspace:*",
    "@cardwise/database-seed": "workspace:*",
    "@cardwise/feature-flags": "workspace:*",
    "@cardwise/jobs": "workspace:*",
    "@cardwise/validation": "workspace:*",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.10.1",
    "@sentry/node": "^9.30.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.56.0",
    "ioredis": "^5.6.1",
    "nestjs-pino": "^4.4.0",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.10.1",
    "supertest": "^7.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
