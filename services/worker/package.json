{
  "name": "@cardwise/worker",
  "version": "0.0.0",
  "private": true,
  "description": "CardWise background worker (BullMQ + Redis)",
  "scripts": {
    "predev": "cd ../api && bun run db:generate",
    "build": "tsc -p tsconfig.json",
    "dev": "bun --env-file=../../.env.example --env-file=../../.env.local --watch src/main.ts",
    "start": "bun --env-file=../../.env.example --env-file=../../.env.local src/main.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@cardwise/ai": "workspace:*",
    "@cardwise/analytics": "workspace:*",
    "@cardwise/feature-flags": "workspace:*",
    "@cardwise/job-runners": "workspace:*",
    "@cardwise/jobs": "workspace:*",
    "@prisma/client": "^6.10.1",
    "@sentry/node": "^9.30.0",
    "bullmq": "^5.56.0",
    "ioredis": "^5.6.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.7.2"
  }
}
