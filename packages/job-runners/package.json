{
  "name": "@cardwise/job-runners",
  "version": "0.0.0",
  "private": true,
  "description": "Background job runner implementations for CardWise workers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@cardwise/ai": "workspace:*",
    "@cardwise/catalog-ingest": "workspace:*",
    "@cardwise/jobs": "workspace:*",
    "@cardwise/validation": "workspace:*",
    "@prisma/client": "^6.10.1"
  },
  "devDependencies": {
    "@cardwise/tsconfig": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
