{
  "name": "@cardwise/database-seed",
  "version": "0.0.0",
  "private": true,
  "description": "Version-controlled seed JSON and loaders for CardWise catalogs",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "echo '@cardwise/database-seed: source package (no build step)'",
    "generate": "bun scripts/generate-seed-data.ts",
    "lint": "echo '@cardwise/database-seed: lint via root oxlint'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@cardwise/validation": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
