{
  "name": "@cardwise/ai-assistant-widget",
  "version": "0.0.0",
  "private": true,
  "description": "Floating AI assistant chat widget for CardWise consumer apps",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "echo '@cardwise/ai-assistant-widget: lint via root oxlint'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@cardwise/ui": "workspace:*",
    "lucide-react": "^0.525.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
