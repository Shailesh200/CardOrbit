{
  "name": "@cardwise/validation",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod validation schemas for CardWise",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "echo '@cardwise/validation: lint via root oxlint'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
