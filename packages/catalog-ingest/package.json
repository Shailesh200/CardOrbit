{
  "name": "@cardwise/catalog-ingest",
  "version": "0.0.0",
  "private": true,
  "description": "Bank-by-bank catalog crawlers for admin ingest review",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@cardwise/validation": "workspace:*"
  },
  "devDependencies": {
    "@cardwise/tsconfig": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.2"
  }
}
