{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && bun install",
  "buildCommand": "cd ../.. && bunx turbo run build --filter=@cardwise/web...",
  "outputDirectory": "dist",
  "ignoreCommand": "cd ../.. && bunx turbo-ignore @cardwise/web",
  "rewrites": [
    {
      "source": "/((?!assets/|icons/|illustrations/|placeholders/|favicon\\.svg|manifest\\.webmanifest|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
