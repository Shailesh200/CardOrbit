{
  "name": "@cardwise/extension",
  "version": "0.1.0",
  "private": true,
  "description": "CardWise browser extension (Manifest V3)",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "lint": "echo '@cardwise/extension: lint via root oxlint'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@cardwise/auth": "workspace:*",
    "@cardwise/design-system": "workspace:*",
    "@cardwise/ui": "workspace:*",
    "@cardwise/validation": "workspace:*",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@tailwindcss/vite": "^4.1.11",
    "@types/chrome": "^0.0.304",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
