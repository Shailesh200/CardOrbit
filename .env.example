# CardWise — Environment template (Phase 0)
# Copy to .env.local for local development: cp .env.example .env.local

# ── Platform ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
LOG_LEVEL=debug

# Brand asset uploads (API serves files from services/api/uploads/)
ASSET_PUBLIC_BASE_URL=http://localhost:3000/assets/files

# Vite consumer web (apps/web)
VITE_API_URL=http://localhost:3000
VITE_SENTRY_DSN=

# Browser extension (apps/extension) — also uses VITE_API_URL above
VITE_WEB_URL=http://localhost:5173
# VITE_EXTENSION_ENABLED=false

# ── Database (PostgreSQL 16 — local Docker) ───────────────────────────────────
DATABASE_URL=postgresql://cardwise:cardwise@localhost:5433/cardwise_dev
DATABASE_POOL_SIZE=10

# Docker Compose overrides (optional — defaults match docker-compose.yml)
POSTGRES_USER=cardwise
POSTGRES_PASSWORD=cardwise
POSTGRES_DB=cardwise_dev
POSTGRES_PORT=5433

# ── Cache (Redis 7 — local Docker) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── Email (Mailpit — local Docker) ───────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cardwise.local
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ── Consumer Auth (M-012) ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-use-openssl-rand-base64-32
JWT_REFRESH_SECRET=change-me-use-openssl-rand-base64-32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/callback
# 32-byte key, base64-encoded (openssl rand -base64 32). Used for Gmail refresh tokens.
TOKEN_ENCRYPTION_KEY=

# ── Admin CMS (M-011) ───────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-admin-use-openssl-rand-base64-32
ADMIN_BOOTSTRAP_EMAIL=admin@cardwise.local
ADMIN_BOOTSTRAP_PASSWORD=cardwise-admin
ADMIN_APP_URL=http://localhost:5174
# Admin Vite app (apps/admin) — also uses VITE_API_URL above

# ── Observability (M-005) ───────────────────────────────────────────────────
# Leave empty locally — Sentry init is a no-op without a DSN.
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Analytics & Feature Flags (M-004) ───────────────────────────────────────
# Leave POSTHOG_API_KEY empty for local in-memory analytics + default flags.
# With a key set, events/flags go to PostHog Cloud.
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_FEATURE_FLAGS_ENABLED=true
# M-023 — PostHog dashboard sync (personal API key + project ID)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Feature flags — managed in Admin portal (Platform → Feature flags), not via .env

# ── Storage (Phase 3+ — not used in Phase 0) ────────────────────────────────
# S3_BUCKET=
# S3_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── AI Platform (Google Gemini — env-configurable models) ────────────────────
# Create key at https://aistudio.google.com/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Optional tier overrides (default to GEMINI_MODEL):
# AI_DEFAULT_FAST_MODEL=gemini-flash-latest
# AI_DEFAULT_QUALITY_MODEL=gemini-flash-latest
# AI_PING_MODEL=gemini-flash-latest
AI_DEFAULT_EMBEDDING_MODEL=text-embedding-004
AI_MONTHLY_BUDGET_USD=50
