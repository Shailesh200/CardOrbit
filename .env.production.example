# CardOrbit — production environment template
# Copy to Coolify / VPS secrets. Never commit real values.
# Generate secrets: openssl rand -base64 32

# ── Platform ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Public URLs (no trailing slash)
# APP_URL = authenticated consumer app (login/account). Landing is the apex domain.
APP_URL=https://app.cardorbit.in
ADMIN_APP_URL=https://admin.cardorbit.in
API_URL=https://api.cardorbit.in
ASSET_PUBLIC_BASE_URL=https://assets.cardorbit.in

# Vite build-time (set in Vercel project env, not on the VPS)
# VITE_API_URL=https://api.cardorbit.in
# VITE_LANDING_ORIGIN=https://cardorbit.in
# VITE_APP_ORIGIN=https://app.cardorbit.in
# VITE_SENTRY_DSN=
# VITE_WEB_URL=https://app.cardorbit.in
# VITE_POSTHOG_KEY=

# ── Images (compose) ────────────────────────────────────────────────────────
IMAGE_REGISTRY=ghcr.io/YOUR_ORG/cardorbit
IMAGE_TAG=latest
API_HOST_PORT=3000

# ── PostgreSQL (Docker on VPS — Phase 1) ────────────────────────────────────
POSTGRES_USER=cardorbit
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=cardorbit
DATABASE_URL=postgresql://cardorbit:change-me-strong-password@postgres:5432/cardorbit
DATABASE_POOL_SIZE=10

# ── Redis (Docker on VPS — Phase 1) ─────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Consumer auth ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
TOKEN_ENCRYPTION_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.example.com/api/v1/auth/oauth/callback

# ── Admin CMS ───────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=

# ── Email (Resend SMTP) ─────────────────────────────────────────────────────
# Resend SMTP: smtp.resend.com:587, user = resend, pass = API key
RESEND_API_KEY=
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
EMAIL_FROM=CardOrbit <noreply@example.com>

# ── AI (Gemini) ─────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
AI_DEFAULT_EMBEDDING_MODEL=text-embedding-004
AI_MONTHLY_BUDGET_USD=50

# ── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Analytics ───────────────────────────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_FEATURE_FLAGS_ENABLED=true

# ── Object storage — Cloudflare R2 (S3-compatible) ──────────────────────────
# Production uploads must NOT use the VPS filesystem.
# Application code still uses local uploads until AssetStorageService is wired
# to these vars — keep them set so Coolify/env is ready.
S3_BUCKET=cardorbit-assets
S3_REGION=auto
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BACKUP_S3_BUCKET=cardorbit-backups
BACKUP_PREFIX=postgres
